{
	"compilerOptions": {
		"declaration": true,
		"declarationDir": "./types",
		"rootDir": "./src",
		"emitDeclarationOnly": true,
		"isolatedModules": true,
		"esModuleInterop": true,
		"allowJs": true,
		"skipLibCheck": true,
		"lib": ["es2015"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules"]
}
